# --- Frontend (Vite) — copy to .env.local ---
# If VITE_AZURE_CLIENT_ID and VITE_AZURE_TENANT_ID are empty, the app uses
# local sign-in: user ID + password stored by the API (see server/data/local-users.json).
# Entra ID app registration: single-page application; redirect URI e.g. http://localhost:5174
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
# Optional: leave unset to use same-origin /api (Vite proxies to the API in dev).
# VITE_API_BASE_URL=

# Optional (local dev): same random string as SCM_INTERNAL_SECRET below — syncs
# finalized quotes to the server and lets Admin read the quote list without Azure JWT.
# VITE_SCM_INTERNAL_SECRET=

# --- API server (Node) — copy to .env in project root or set in shell ---
# Same tenant as the SPA; used to validate JWT issuer and JWKS.
AZURE_TENANT_ID=
# Optional: comma-separated accepted token audiences (default: Microsoft Graph).
# AZURE_EXPECTED_AUDIENCES=https://graph.microsoft.com,00000003-0000-0000-c000-000000000000

# Comma-separated Azure AD user Object IDs (oid) allowed to open /admin.
ADMIN_OBJECT_IDS=

# --- PostgreSQL (quotes, drafts, OVF, PO workflow data) ---
# Create database in pgAdmin (name: scm_workflow), run server/db/schema.sql, then set:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/scm_workflow
# Without DATABASE_URL, quotes stay in browser localStorage only.

PORT=3002

# Optional (local dev): must match VITE_SCM_INTERNAL_SECRET for quote registry POST/GET.
# SCM_INTERNAL_SECRET=

# --- Local username/password auth (API server) ---
# Strong secret for signing local JWT sessions (required in production).
# LOCAL_JWT_SECRET=
# Optional: create one admin on first server start if the user store is empty.
# LOCAL_SEED_ADMIN_USERNAME=
# LOCAL_SEED_ADMIN_PASSWORD=
# LOCAL_SEED_ADMIN_DISPLAY_NAME=
# LOCAL_SEED_ADMIN_EMAIL=

# --- OpenAI (API server only — never prefix with VITE_) ---
# Used by POST /api/ovf/extract-customer-party and /api/ovf/extract-vendor-party.
# OPENAI_API_KEY=
# Optional model (default gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
